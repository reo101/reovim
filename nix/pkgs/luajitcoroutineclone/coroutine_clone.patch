+LJLIB_CF(coroutine_clone)
+{
+  ErrMsg em;
+  lua_State *L1;
+  lua_State *L2;
+
+  // Check if the argument is a coroutine
+  if (!(L->base < L->top && tvisthread(L->base)))
+    lj_err_arg(L, 1, LJ_ERR_NOCORO);
+
+  // Fetch the original coroutine
+  L1 = threadV(L->base);
+
+  // Only clone coroutines that coroutine.resume would accept.
+  if (L1->cframe != NULL || L1->status > LUA_YIELD ||
+      (L1->status == LUA_OK && L1->top == L1->base)) {
+    em = L1->cframe ? LJ_ERR_CORUN : LJ_ERR_CODEAD;
+    lj_err_caller(L, em);
+  }
+
+  // Clone the coroutine using lj_clonethread
+  L2 = lj_clonethread(L, L1);
+
+  // Return the cloned coroutine
+  setthreadV(L, L->top++, L2);
+
+  return 1;
+}

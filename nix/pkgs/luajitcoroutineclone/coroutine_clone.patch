+LUA_API lua_State *lj_clonethread(lua_State *L, lua_State *from) {
+  lua_State *to;
+  TValue *f, *t, *tend;
+
+  // Create a new thread
+  to = lj_state_new(L);
+
+  // Grow the destination stack to match the source stack capacity.
+  if (to->stacksize < from->stacksize)
+    lj_state_growstack(to, from->stacksize - LJ_STACK_EXTRA - 1);
+
+  // Copy stack slots
+  for (f = tvref(from->stack), t = tvref(to->stack); f < from->top; f++, t++) {
+    copyTV(to, t, f);
+  }
+  to->top = t;
+  tend = tvref(to->stack) + to->stacksize;
+  for (; t < tend; t++) {
+    setnilV(t);
+  }
+
+  // stack[0] stores the current thread for curr_funcisL() on empty stacks.
+  setthreadV(to, tvref(to->stack), to);
+  to->base = tvref(to->stack) + (from->base - tvref(from->stack));
+
+  // Copy other relevant fields
+  to->status = from->status;
+  to->cframe = NULL;
+  setmrefr(to->glref, from->glref);
+
+  // Copy GC-managed references without reinterpreting them as raw pointers.
+  setgcrefr(to->env, from->env);
+
+  // Return the new thread
+  return to;
+}
